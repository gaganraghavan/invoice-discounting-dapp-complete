# ─── Smart Contract Environment Variables ───────────────────────────────────
# Copy this file to .env and fill in your values.
# DO NOT commit .env to git.

# ─── Ganache (local development) ────────────────────────────────────────────
# Default Ganache GUI URL (port 7545)
GANACHE_RPC_URL=http://127.0.0.1:7545

# Three stakeholder private keys from Ganache accounts
# (Table 1 in paper: Supplier, Buyer, Financier have separate Ethereum addresses)
# Copy these from the Ganache GUI "Accounts" tab (click the key icon)
SUPPLIER_PRIVATE_KEY=0xyour_supplier_ganache_private_key
BUYER_PRIVATE_KEY=0xyour_buyer_ganache_private_key
FINANCIER_PRIVATE_KEY=0xyour_financier_ganache_private_key

# ─── Sepolia Testnet ─────────────────────────────────────────────────────────
# Get a free RPC URL from Alchemy (https://dashboard.alchemy.com) or Infura
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/your_alchemy_api_key

# Deployer account private key (export from MetaMask: Account → Export Private Key)
# This account needs Sepolia ETH — get free from https://sepoliafaucet.com
DEPLOYER_PRIVATE_KEY=0xyour_metamask_private_key

# ─── Etherscan ───────────────────────────────────────────────────────────────
# For contract verification (seniors verified theirs on Etherscan Sepolia)
# Get free key from https://etherscan.io/register
ETHERSCAN_API_KEY=your_etherscan_api_key
