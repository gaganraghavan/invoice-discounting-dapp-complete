# ─── Backend Environment Variables ──────────────────────────────────────────
# Paper: "A Non-Fungible Token Based Approach to Invoice Discounting"
# PES University — Node.js + Express.js backend (Section V)
#
# Copy this to .env and fill in values AFTER running deploy.js
# These values come from:
#   - Ganache GUI (private keys + RPC URL)
#   - backend/src/contracts/contractAddress.json (after deployment)
#   - web3.storage (IPFS token)

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Network Selection ───────────────────────────────────────────────────────
# Options: "ganache" or "sepolia"
# Paper used Sepolia (Section V: "deployed on Sepolia Ethereum testnet")
NETWORK=ganache

# ─── Blockchain RPC ──────────────────────────────────────────────────────────
# For ganache: use Ganache GUI default
GANACHE_RPC_URL=http://127.0.0.1:7545

# For Sepolia: get from Alchemy (https://dashboard.alchemy.com)
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/your_alchemy_api_key

# ─── Smart Contract ──────────────────────────────────────────────────────────
# Fill in AFTER running: npx hardhat run scripts/deploy.js --network ganache
# This is printed to console during deployment and saved to
# backend/src/contracts/contractAddress.json automatically
CONTRACT_ADDRESS=0x_fill_after_deployment

# ─── Stakeholder Private Keys ────────────────────────────────────────────────
# Paper Table 1: Three separate Ethereum addresses for Supplier, Buyer, Financier
# For Ganache: copy from Ganache GUI "Accounts" tab (click key icon per account)
# For Sepolia: export from MetaMask (Settings → Security → Export Private Key)
#
# These are used by the backend to sign transactions on behalf of each party.
# In production, the frontend would use MetaMask directly.
# For this replica (Postman testing), the backend holds the keys.
SUPPLIER_PRIVATE_KEY=0xyour_supplier_private_key
BUYER_PRIVATE_KEY=0xyour_buyer_private_key
FINANCIER_PRIVATE_KEY=0xyour_financier_private_key

# ─── IPFS via web3.storage ───────────────────────────────────────────────────
# Paper Section V: "IPFS integration facilitated through Node.js using web3storage.js module"
# Get your API token from: https://web3.storage (free account)
# Click "Create API Token" on the dashboard
WEB3_STORAGE_TOKEN=your_web3storage_api_token

# ─── IPFS Gateway ────────────────────────────────────────────────────────────
# Public IPFS gateway for viewing uploaded invoice PDFs
IPFS_GATEWAY=https://w3s.link/ipfs
